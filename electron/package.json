{
    "name": "donote-desktop",
    "productName": "Donote",
    "version": "1.0.0",
    "description": "Donote desktop shell for macOS",
    "private": true,
    "main": "main.js",
    "scripts": {
        "build:eventkit": "swiftc -O eventkit/donote-eventkit.swift -o eventkit/donote-eventkit",
        "prestart": "npm run build:eventkit",
        "start": "electron .",
        "prepack": "npm run build:eventkit",
        "pack": "electron-builder --mac --dir",
        "predist": "npm run build:eventkit",
        "dist": "electron-builder --mac"
    },
    "devDependencies": {
        "electron": "^38.1.0",
        "electron-builder": "^26.0.12"
    },
    "build": {
        "appId": "io.air.donote",
        "productName": "Donote",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "offline.html"
        ],
        "extraResources": [
            {
                "from": "eventkit/donote-eventkit",
                "to": "eventkit/donote-eventkit"
            }
        ],
        "mac": {
            "category": "public.app-category.productivity",
            "target": [
                "dmg",
                "zip"
            ],
            "hardenedRuntime": true,
            "gatekeeperAssess": false,
            "extendInfo": {
                "NSCalendarsUsageDescription": "Donote shows your calendar events next to your notes.",
                "NSCalendarsFullAccessUsageDescription": "Donote shows your calendar events next to your notes."
            }
        }
    }
}
